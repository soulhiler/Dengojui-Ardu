#pragma once

/**

 * Скопируй в secrets.h и подставь свой пароль Wi-Fi.

 * Файл secrets.h в репозиторий не попадает (.gitignore).

 *

 * Если на роутере другое имя сети (2.4 ГГц) — раскомментируй и задай точные SSID:

 *   #define XIAO_WIFI_SSID_1 "Имя_сети_с_роутера"

 *   #define XIAO_WIFI_SSID_2 "Запасное_или_то_же"

 * Иначе в прошивке остаются значения по умолчанию из xiao_cam_stream.ino.

 */

static const char *kWifiPass = "YOUR_WIFI_PASSWORD";

/**
 * OTA по Wi-Fi (arduino-cli / Arduino IDE 2, инструмент esp_ota).
 * Оставь "" — OTA отключён. Иначе строка в кавычках — пароль для загрузки по сети.
 */
#define XIAO_OTA_PASSWORD ""

/**
 * Токен-авторизация эндпоинтов управления (/drive /control /scan360 /beep /melody).
 * Пусто "" — авторизация ВЫКЛ (открыто, только для доверенной LAN).
 * ОБЯЗАТЕЛЬНО задай непустой токен ПЕРЕД любым выходом в интернет (relay/VPN).
 * Клиент шлёт его как ?token=… или заголовок X-Auth-Token.
 */
#define XIAO_API_TOKEN ""

/**
 * Своя точка доступа робота (прямая связь робот↔телефон без роутера, IP 192.168.4.1).
 * Пароль — минимум 8 символов (WPA2). СМЕНИ дефолт.
 */
#define XIAO_AP_SSID "XIAO-Robot"
#define XIAO_AP_PASSWORD "xiaorobot"

