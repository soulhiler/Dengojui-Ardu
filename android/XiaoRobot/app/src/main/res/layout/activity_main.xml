<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="12dp">

    <!-- Вкладка «Робот»: камера, джойстик, базовая телеметрия (статус-строка) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/pageRobot"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/ipLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_ip"
            app:layout_constraintEnd_toStartOf="@id/btnConnect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="xiao-cam.local" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/connect"
            app:layout_constraintBottom_toBottomOf="@id/ipLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ipLayout" />

        <ImageView
            android:id="@+id/videoView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:background="#000000"
            android:contentDescription="camera"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toTopOf="@id/statusText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ipLayout"
            app:layout_constraintHeight_min="120dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#8B949E"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/videoView" />

        <com.denzhogzhuy.xiaorobot.JoystickView
            android:id="@+id/joystick"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnColumn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusText" />

        <LinearLayout
            android:id="@+id/btnColumn"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/joystick"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/joystick">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMic"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mic_on" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/motor_stop" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Вкладка «Телеметрия»: сводка 10 показателей + группы как в веб-дашборде -->
    <ScrollView
        android:id="@+id/pageTelemetry"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/telemetryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="12dp" />
    </ScrollView>

    <!-- Вкладка «Управление»: тогглы /control, мощность, пение, звук, обновление -->
    <ScrollView
        android:id="@+id/pageControls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="12dp">

            <TextView
                style="@style/CtrlHeader"
                android:text="@string/ctrl_board" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swWifi"
                style="@style/CtrlSwitch"
                android:text="@string/ctrl_wifi" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swBle"
                style="@style/CtrlSwitch"
                android:text="@string/ctrl_ble" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swCam"
                style="@style/CtrlSwitch"
                android:text="@string/ctrl_cam" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swMic"
                style="@style/CtrlSwitch"
                android:text="@string/ctrl_mic" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swDrive"
                style="@style/CtrlSwitch"
                android:text="@string/ctrl_drive" />

            <TextView
                style="@style/CtrlHeader"
                android:text="@string/ctrl_drive_params" />

            <TextView
                android:id="@+id/lblPower"
                style="@style/CtrlLabel" />

            <SeekBar
                android:id="@+id/seekPower"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="40"
                android:max="255" />

            <TextView
                android:id="@+id/lblGain"
                style="@style/CtrlLabel" />

            <SeekBar
                android:id="@+id/seekGain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="10"
                android:max="100" />

            <TextView
                style="@style/CtrlHeader"
                android:text="@string/ctrl_sound" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBeep"
                    style="@style/CtrlButton"
                    android:text="@string/snd_beep" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMelody1"
                    style="@style/CtrlButton"
                    android:text="@string/snd_melody1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSayHi"
                    style="@style/CtrlButton"
                    android:text="@string/snd_hi" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSoundStop"
                    style="@style/CtrlButton"
                    android:text="@string/snd_stop" />
            </LinearLayout>

            <TextView
                style="@style/CtrlHeader"
                android:text="@string/ctrl_app" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_update" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        app:itemIconTint="#5CADFF"
        app:itemTextColor="#8B949E"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav" />

</androidx.constraintlayout.widget.ConstraintLayout>
